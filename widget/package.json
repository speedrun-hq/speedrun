{
  "name": "@speedrun/widget",
  "version": "0.1.0",
  "description": "Cross-chain token transfer widget for DeFi applications",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && rollup -c",
    "dev": "rollup -c -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint 'src/**/*.{js,ts,tsx}'",
    "format": "prettier --write 'src/**/*.{js,ts,tsx}'",
    "prepack": "npm run build",
    "prepublishOnly": "npm run test && npm run lint"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "wagmi": "^1.0.0"
  },
  "dependencies": {
    "@ethersproject/providers": "^5.7.0",
    "@ethersproject/units": "^5.7.0",
    "@speedrun/components": "^0.1.0",
    "@speedrun/utils": "^0.1.0",
    "axios": "^1.4.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^24.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.5.0",
    "msw": "^1.2.1",
    "prettier": "^2.8.7",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "rimraf": "^5.0.0",
    "rollup": "^3.0.0",
    "rollup-plugin-peer-deps-external": "^2.2.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "wagmi": "^1.3.9"
  },
  "keywords": [
    "speedrun",
    "widget",
    "defi",
    "cross-chain",
    "intent",
    "transfer",
    "blockchain",
    "ethereum",
    "web3"
  ],
  "author": "Speedrun Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/speedrun-hq/speedrun"
  },
  "publishConfig": {
    "access": "public"
  }
} 